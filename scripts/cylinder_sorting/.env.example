# Copy this file to `.env` in this directory (same folder as `supabase_atoms_rest.py`).
# Repo-root `.env` is also loaded if present. Real `.env` files are gitignored.

SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional alias (used only if SUPABASE_ANON_KEY is unset):
# SUPABASE_KEY=

# Optional — bypasses RLS; server-only, never commit:
# SUPABASE_SERVICE_ROLE_KEY=

# ATOMS project UUID (required for the bridge; smoke test uses this or built-in Arm default)
ATOMS_PROJECT_ID=95fa5a31-7beb-4629-80d5-bb2a8d07c3e2

# Optional — sort_controller.py read-only REST poll during DETECTING (GET only, no writes).
# GETs are throttled (default 30s between requests) so we do not hammer PostgREST every ~0.3s.
# Setting only here is enough; atoms_read_poll loads this .env before checking the flag.
# ATOMS_REST_POLL=1
# ATOMS_REST_POLL_INTERVAL_SEC=30
# ATOMS_READ_TITLE_PREFIX=IF-008

# ATOMS → sort_config.json bridge (runs inside each successful REST poll, same cadence).
# Parse desired enabled_colors from the requirement body; write sort_config.json
# atomically only when the rendered config changes; sort_controller hot-reloads it.
# Robot model paths stay local (never pulled from ATOMS). Unset colors are skipped.
# ATOMS_BRIDGE_MODEL_GREEN=outputs/train/act_green_v1_laptop_100k/checkpoints/last/pretrained_model
# ATOMS_BRIDGE_MODEL_BLUE=outputs/train/act_blue_v1_laptop_100k/checkpoints/last/pretrained_model
# ATOMS_BRIDGE_MODEL_YELLOW=
